# SBCL compiled binary (name matches :build-pathname in cl-tmux.asd)
/cl-tmux
/cl-tmux.core

# Nix build output symlink
/result

# Claude Code harness internals
/.claude/

# ASDF fasls normally go to ~/.cache, but ad-hoc compile-file runs can leave
# .fasl objects in the tree — never track them.
*.fasl
