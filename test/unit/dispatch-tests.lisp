         (w0 (first  (session-windows s)))
         (w2 (third  (session-windows s))))
    (with-loop-state
      ;; Start at w0; prev-cyclic wraps to w2 (the last window).
      (is (eq w0 (session-active-window s)))
      (cl-tmux::%cmd-cycle-window s #'cl-tmux::prev-cyclic)
